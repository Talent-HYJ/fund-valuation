<view class="page-wrap theme-{{theme}}">
<view class="container">
  <view class="card">
    <view class="form-item">
      <text class="label">基金代码</text>
      <input placeholder="6位代码" value="{{code}}" bindinput="onCodeInput" class="input" disabled="{{isEdit}}" />
    </view>
    <view class="form-item">
      <text class="label">持有份额</text>
      <input type="digit" placeholder="份" value="{{shares}}" bindinput="onSharesInput" class="input" />
    </view>
    <view class="form-item">
      <text class="label">成本净值</text>
      <input type="digit" placeholder="元/份" value="{{cost}}" bindinput="onCostInput" class="input" />
    </view>
  </view>
  <button class="btn-submit" bindtap="submit">确认添加</button>
</view>
</view>
