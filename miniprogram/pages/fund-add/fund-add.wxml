<view class="page-wrap theme-{{theme}}">
<view class="container">
  <view class="ocr-row">
    <button class="btn-ocr" bindtap="chooseImageForOcr" disabled="{{ocrLoading}}">{{ocrLoading ? '识别中...' : '从图片识别导入'}}</button>
  </view>
  <view class="card">
    <view class="form-item">
      <text class="label">鸡蛋类型</text>
      <input placeholder="6位代码" value="{{code}}" bindinput="onCodeInput" class="input" disabled="{{isEdit}}" />
    </view>
    <view class="form-item">
      <text class="label">鸡蛋份额</text>
      <input type="digit" placeholder="份" value="{{shares}}" bindinput="onSharesInput" class="input" />
    </view>
    <view class="form-item">
      <text class="label">鸡蛋单价</text>
      <input type="digit" placeholder="元/份" value="{{cost}}" bindinput="onCostInput" class="input" />
    </view>
    <view class="form-item">
      <text class="label">补蛋阈值</text>
      <input type="digit" placeholder="默认3%" value="{{replenishThreshold}}" bindinput="onReplenishThresholdInput" class="input" />
    </view>
  </view>
  <button class="btn-submit" bindtap="submit">确认添加</button>
</view>
</view>
