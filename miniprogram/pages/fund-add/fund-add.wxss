.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.form-item { margin-bottom: 24rpx; }
.form-item .label { display: block; color: #666; font-size: 26rpx; margin-bottom: 8rpx; }
.input { border: 1rpx solid #eee; border-radius: 8rpx; padding: 20rpx; font-size: 28rpx; }
.page-wrap { min-height: 100%; }
.page-wrap.theme-red { background: #fff5f5; }
.page-wrap.theme-green { background: #f5fff5; }
.btn-submit { color: #fff; border-radius: 12rpx; margin-top: 24rpx; }
.theme-red .btn-submit { background: #e74c3c; }
.theme-green .btn-submit { background: #1aad19; }
