<view class="page-wrap theme-{{theme}}">
<view class="container">
  <view class="card summary" wx:if="{{hasFunds}}">
    <view class="summary-row">
      <view class="col"><text class="label">今日鸡蛋</text><text class="value {{todayEarn >= 0 ? 'up' : 'down'}}"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{todayEarn}}</text></view>
      <view class="col"><text class="label">本月鸡蛋</text><text class="value {{monthEarn >= 0 ? 'up' : 'down'}}"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{monthEarn}}</text></view>
      <view class="col"><text class="label">收货鸡蛋</text><text class="value {{totalEarn >= 0 ? 'up' : 'down'}}"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{totalEarn}}</text></view>
    </view>
  </view>

  <view class="card calendar-card" wx:if="{{hasFunds}}">
    <view class="cal-header">
      <text class="cal-arrow" bindtap="prevYear">‹‹</text>
      <text class="cal-arrow" bindtap="prevMonth">‹</text>
      <text class="cal-title">{{calYear}}年{{calMonth}}月</text>
      <text class="cal-arrow" bindtap="nextMonth">›</text>
      <text class="cal-arrow" bindtap="nextYear">››</text>
    </view>
    <view class="week-row">
      <text class="week-item" wx:for="{{calendar.weekdays}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="day-grid">
      <view class="day-cell {{item.empty ? 'empty' : ''}}" wx:for="{{calendar.cells}}" wx:key="id">
        <view wx:if="{{!item.empty}}">
          <text class="day-num">{{item.day}}</text>
          <text class="day-earn {{item.cls}}">{{item.earnText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{loading}}">加载中...</view>
  <view class="card empty" wx:elif="{{!hasFunds}}">暂无鸡蛋，请在首页添加</view>
</view>
<view class="sync-bar theme-{{theme}}">
  <button class="sync-btn" bindtap="onSync" disabled="{{syncing}}">{{syncing ? '同步中...' : '数据同步'}}</button>
</view>
</view>
