.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 20rpx;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.header { flex-shrink: 0; }
.list-scroll {
  flex: 1;
  min-height: 0;
  margin-bottom: 24rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.summary .col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.summary .label { color: #666; font-size: 24rpx; }
.summary .value { font-size: 28rpx; font-weight: 500; }

.indices-wrap { margin: 0 0 24rpx; border-radius: 16rpx; overflow: hidden; }
.indices-scroll { width: 100%; white-space: nowrap; }
.indices-scroll .indices-row { display: flex; padding: 8rpx 0; width: 1160rpx; }
.indices-scroll .idx {
  flex-shrink: 0;
  width: 180rpx;
  margin-left: 16rpx;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  box-sizing: border-box;
}
.indices-scroll .idx:first-child { margin-left: 0; }
.idx-name { font-size: 22rpx; color: rgba(0,0,0,0.7); }
.idx-val { font-size: 28rpx; font-weight: 600; color: #333; }
.idx-pct { font-size: 22rpx; }
.idx-pct.up { color: #b71c1c; }
.idx-pct.down { color: #1aad19; }

.label { color: #666; font-size: 28rpx; }
.value { font-size: 32rpx; font-weight: 500; }
.up { color: #e74c3c; }
.down { color: #27ae60; }

.list-title { font-weight: 600; margin-bottom: 16rpx; }
.item {
  position: relative;
  overflow: hidden;
  border-bottom: 1rpx solid #f0f0f0;
}
.item:last-child { border-bottom: none; }
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 220rpx;
  padding-left: 16rpx;
  box-sizing: border-box;
  display: flex;
  visibility: hidden;
  pointer-events: none;
}
.item.opened .swipe-actions {
  visibility: visible;
  pointer-events: auto;
}
.action-btn {
  flex: 1;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}
.action-edit { background: #f5a623; }
.action-del { background: #e74c3c; }
.item-main {
  position: relative;
  background: #fff;
  padding: 20rpx 0;
  transition: transform 0.2s ease;
}
.item-main.open { transform: translateX(-236rpx); }
.item-name { font-size: 28rpx; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-code { color: #999; font-size: 24rpx; margin-left: 4rpx; }
.item-row { display: flex; justify-content: space-between; font-size: 24rpx; color: #666; }

.empty { text-align: center; color: #999; padding: 48rpx; }
.page-wrap { min-height: 100%; }
.page-wrap.theme-red { background: #fff5f5; }
.page-wrap.theme-green { background: #f5fff5; }
.btn-add { flex-shrink: 0; width: 100%; margin: 0; color: #fff; border-radius: 12rpx; box-sizing: border-box; }
.theme-red .btn-add { background: #e74c3c; }
.theme-green .btn-add { background: #1aad19; }
