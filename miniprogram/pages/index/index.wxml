<view class="page-wrap theme-{{theme}}">
<view class="container">
  <view class="header">
    <view class="card summary">
      <view class="summary-row">
        <view class="col"><text class="label">今日鸡蛋</text><text class="value {{todayEarnings >= 0 ? 'up' : 'down'}}"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{todayEarnings}}</text></view>
        <view class="col"><text class="label">鸡蛋总价</text><text class="value"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{totalAmount}}</text></view>
        <view class="col"><text class="label">收货鸡蛋</text><text class="value {{totalEarnings >= 0 ? 'up' : 'down'}}"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{totalEarnings}}</text></view>
      </view>
    </view>
    <view class="indices-wrap" wx:if="{{indices.length}}">
      <scroll-view class="indices-scroll" scroll-x>
        <view class="indices-row">
          <view class="idx" wx:for="{{indices}}" wx:key="name" style="{{item.bgStyle}}">
            <text class="idx-name">{{item.name}}</text>
            <text class="idx-val">{{item.current}}</text>
            <text class="idx-pct {{item.isUp ? 'up' : 'down'}}" wx:if="{{item.changePct}}">{{item.changePct > 0 ? '+' : ''}}{{item.changePct}}%</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <scroll-view class="list-scroll" scroll-y>
    <view class="card" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="card list-card" wx:elif="{{list.length}}">
      <view class="list-title">全部鸡蛋</view>
      <view class="item {{item.open ? 'opened' : ''}}" wx:for="{{list}}" wx:key="code">
      <view class="swipe-actions">
        <view class="action-btn action-edit" data-code="{{item.code}}" bindtap="editFund">修改</view>
        <view class="action-btn action-del" data-code="{{item.code}}" bindtap="deleteFund">删除</view>
      </view>
      <view
        class="item-main {{item.open ? 'open' : ''}}"
        data-code="{{item.code}}"
        bindtap="toDetail"
        bindtouchstart="onItemTouchStart"
        bindtouchend="onItemTouchEnd"
      >
        <view class="item-name">{{item.name || item.code}}<text class="item-code" wx:if="{{item.name}}"> ({{item.code}})</text></view>
        <view class="item-row">
          <text>份量 {{item.gsz != null ? item.gsz : '-'}}</text>
          <text class="{{item.gszzl >= 0 ? 'up' : 'down'}}" wx:if="{{item.gszzl != null}}">{{item.gszzl}}%</text>
        </view>
        <view class="item-row">
          <text>昨天份量</text>
          <text class="{{item.lastDayPct == null ? '' : (item.lastDayPct >= 0 ? 'up' : 'down')}}">
            <text wx:if="{{item.lastDayPct == null}}">-</text>
            <text wx:else>{{item.lastDayPct >= 0 ? '+' : ''}}{{item.lastDayPct}}%</text>
          </text>
        </view>
        <view class="item-row" wx:if="{{item.market}}">
          <text>市场份量 <image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{item.market}}</text>
          <text class="{{item.todayEarn >= 0 ? 'up' : 'down'}}">今日 <image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{item.todayEarn}}</text>
        </view>
        <view class="item-row" wx:if="{{item.earn != null}}">
          <text>我的鸡蛋</text>
          <text class="{{item.earn >= 0 ? 'up' : 'down'}}"><image class="amount-icon" src="/images/tab-fund.svg" mode="aspectFit"></image>{{item.earn}}</text>
        </view>
      </view>
    </view>
    </view>
    <view class="card empty" wx:else>
      <text>暂无鸡蛋，点击下方添加</text>
    </view>
  </scroll-view>

  <button class="btn-add" bindtap="toAdd">+ 添加鸡蛋</button>
</view>
</view>
